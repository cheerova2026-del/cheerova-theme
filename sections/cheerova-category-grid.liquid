<div class="color-{{ section.settings.color_scheme }} gradient">
<div class="page-width" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
{% if section.settings.heading != blank %}<h2 class="cheerova-cat-title">{{ section.settings.heading }}</h2>{% endif %}
{% if section.settings.subheading != blank %}<p class="cheerova-cat-sub">{{ section.settings.subheading }}</p>{% endif %}
<div class="cheerova-cat-grid">
{% for block in section.blocks %}{% assign col = block.settings.collection %}<a class="cheerova-cat-card" href="{{ col.url | default: '#' }}" {{ block.shopify_attributes }}><div class="cheerova-cat-img">{% if col.featured_image %}<img src="{{ col.featured_image | image_url: width: 600 }}" alt="{{ col.title | escape }}" loading="lazy" width="600" height="513">{% endif %}</div><div class="cheerova-cat-label"><span class="cheerova-cat-icon" style="color:{% if block.settings.icon_color == 'orange' %}#E8813A{% else %}#7A5CC7{% endif %}">{% case block.settings.icon %}{% when 'top_hat' %}<svg viewBox="0 0 24 24"><path d="M8 3h8a1 1 0 0 1 1 1v9h3v3H4v-3h3V4a1 1 0 0 1 1-1z"/></svg>{% when 'witch_hat' %}<svg viewBox="0 0 24 24"><path d="M12 2l5 10H7l5-10zM4 13h16v3H4z"/></svg>{% when 'mask' %}<svg viewBox="0 0 24 24"><circle cx="7" cy="13" r="4.2"/><circle cx="17" cy="13" r="4.2"/><rect x="9" y="12" width="6" height="2"/></svg>{% when 'crown' %}<svg viewBox="0 0 24 24"><path d="M3 19h18v2H3zM3 17l1.2-8L9 12l3-7 3 7 4.8-3L21 17H3z"/></svg>{% when 'pumpkin' %}<svg viewBox="0 0 24 24"><rect x="11" y="3" width="2.4" height="4" rx="1"/><ellipse cx="12" cy="14" rx="8.5" ry="7"/></svg>{% when 'ghost' %}<svg viewBox="0 0 24 24"><path d="M12 3a7 7 0 0 0-7 7v11l2.5-2 2.5 2 2-2 2 2 2.5-2 2.5 2V10a7 7 0 0 0-7-7z"/><circle cx="9.5" cy="10" r="1.2" fill="#fff"/><circle cx="14.5" cy="10" r="1.2" fill="#fff"/></svg>{% when 'house' %}<svg viewBox="0 0 24 24"><path d="M12 3l9 8h-2.5v9H14v-6h-4v6H5.5v-9H3l9-8z"/></svg>{% when 'tombstone' %}<svg viewBox="0 0 24 24"><path d="M12 3a6.5 6.5 0 0 0-6.5 6.5V19h13V9.5A6.5 6.5 0 0 0 12 3z"/><rect x="4" y="19" width="16" height="2" rx="1"/></svg>{% when 'skull' %}<svg viewBox="0 0 24 24"><path d="M12 2a8.5 8.5 0 0 0-8.5 8.5c0 3 1.7 5.3 4 6.6V20a2 2 0 0 0 2 2h5a2 2 0 0 0 2-2v-2.9c2.3-1.3 4-3.6 4-6.6A8.5 8.5 0 0 0 12 2z"/><circle cx="9" cy="11" r="1.8" fill="#fff"/><circle cx="15" cy="11" r="1.8" fill="#fff"/></svg>{% when 'candy' %}<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="4.5"/><path d="M7.5 12L3 7.5v9L7.5 12zm9 0L21 16.5v-9L16.5 12z"/></svg>{% endcase %}</span><span>{{ col.title | default: 'Category' }}</span></div></a>{% endfor %}
</div>
</div>
</div>
<style>
.cheerova-cat-title{text-align:center;margin:0 0 6px;font-family:var(--font-heading-family);font-weight:var(--font-heading-weight);font-size:calc(var(--font-heading-scale)*2.8rem);line-height:1.15}
.cheerova-cat-sub{text-align:center;margin:0 0 26px;opacity:.72;font-size:1.5rem}
.cheerova-cat-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:13px}
@media(min-width:750px){.cheerova-cat-grid{grid-template-columns:repeat(3,1fr);gap:18px}}
@media(min-width:990px){.cheerova-cat-grid{grid-template-columns:repeat(5,1fr)}}
.cheerova-cat-card{display:block;border-radius:14px;overflow:hidden;text-decoration:none;background:#ffffff;transition:transform .2s ease,box-shadow .2s ease}
.cheerova-cat-card:hover{transform:translateY(-4px);box-shadow:0 12px 26px rgba(0,0,0,.4)}
.cheerova-cat-img{aspect-ratio:284/243;background:#1E1830}
.cheerova-cat-img img{width:100%;height:100%;object-fit:cover;display:block}
.cheerova-cat-label{display:flex;align-items:center;gap:9px;background:#ffffff;color:#16121F;padding:12px 13px;font-weight:600;font-size:1.35rem;line-height:1.25;font-family:var(--font-body-family)}
.cheerova-cat-icon svg{width:20px;height:20px;display:block;fill:currentColor}
</style>
{% schema %}
{"name":"Cheerova category grid","settings":[{"type":"text","id":"heading","label":"Heading","default":"Shop by category"},{"type":"text","id":"subheading","label":"Subheading","default":"Explore costumes, decor, accessories, and party essentials."},{"type":"color_scheme","id":"color_scheme","label":"Color scheme","default":"scheme-1"},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding top","default":40},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding bottom","default":44}],"blocks":[{"type":"category","name":"Category card","settings":[{"type":"collection","id":"collection","label":"Collection"},{"type":"select","id":"icon","label":"Icon","default":"pumpkin","options":[{"value":"top_hat","label":"Top hat"},{"value":"witch_hat","label":"Witch hat"},{"value":"mask","label":"Mask"},{"value":"crown","label":"Crown"},{"value":"pumpkin","label":"Pumpkin"},{"value":"ghost","label":"Ghost"},{"value":"house","label":"House"},{"value":"tombstone","label":"Tombstone"},{"value":"skull","label":"Skull"},{"value":"candy","label":"Candy"}]},{"type":"select","id":"icon_color","label":"Icon color","default":"purple","options":[{"value":"purple","label":"Purple"},{"value":"orange","label":"Orange"}]}]}],"max_blocks":12,"presets":[{"name":"Cheerova category grid"}]}
{% endschema %}
