<div class="color-{{ section.settings.color_scheme }} gradient">
<div class="page-width" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
{% if section.settings.heading != blank %}<h2 class="cheerova-testi__h">{{ section.settings.heading }}</h2>{% endif %}
{% if section.settings.subheading != blank %}<p class="cheerova-testi__sub">{{ section.settings.subheading }}</p>{% endif %}
<div class="cheerova-testi-grid">
{% for block in section.blocks %}<div class="cheerova-testi color-scheme-2 gradient" {{ block.shopify_attributes }}><div class="cheerova-testi__stars">{% for i in (1..5) %}<svg viewBox="0 0 24 24"><path d="M12 2l3 6.5 7 .8-5 4.8 1.3 7-6.3-3.6-6.3 3.6 1.3-7-5-4.8 7-.8z"/></svg>{% endfor %}</div><p class="cheerova-testi__quote">{{ block.settings.quote }}</p><span class="cheerova-testi__name">{{ block.settings.name }}</span></div>{% endfor %}
</div>
</div>
</div>
<style>
.cheerova-testi__h{text-align:center;margin:0 0 6px;font-family:var(--font-heading-family);font-weight:var(--font-heading-weight);font-size:calc(var(--font-heading-scale)*2.4rem)}
.cheerova-testi__sub{text-align:center;margin:0 0 26px;opacity:.72;font-size:1.4rem}
.cheerova-testi-grid{display:grid;grid-template-columns:1fr;gap:16px}
@media(min-width:750px){.cheerova-testi-grid{grid-template-columns:repeat(3,1fr);gap:20px}}
.cheerova-testi{border-radius:14px;padding:22px;border:1px solid rgba(255,255,255,.08)}
.cheerova-testi__stars{display:flex;gap:3px;margin-bottom:12px}
.cheerova-testi__stars svg{width:16px;height:16px;fill:#E8813A}
.cheerova-testi__quote{font-size:1.45rem;line-height:1.55;margin:0 0 14px}
.cheerova-testi__name{font-size:1.3rem;opacity:.7;font-weight:600}
</style>
{% schema %}
{"name":"Cheerova testimonials","settings":[{"type":"text","id":"heading","label":"Heading","default":"What our customers say"},{"type":"text","id":"subheading","label":"Subheading","default":"Illustrative reviews \u2014 replace with real customer quotes anytime."},{"type":"color_scheme","id":"color_scheme","label":"Color scheme","default":"scheme-1"},{"type":"range","id":"padding_top","min":0,"max":80,"step":4,"unit":"px","label":"Padding top","default":44},{"type":"range","id":"padding_bottom","min":0,"max":80,"step":4,"unit":"px","label":"Padding bottom","default":52}],"blocks":[{"type":"quote","name":"Quote","settings":[{"type":"textarea","id":"quote","label":"Quote","default":"Amazing quality and fast shipping!"},{"type":"text","id":"name","label":"Name","default":"Sample reviewer"}]}],"max_blocks":6,"presets":[{"name":"Cheerova testimonials","blocks":[{"type":"quote","settings":{"quote":"The costume quality blew me away \u2014 it looked even better in person.","name":"Illustrative review"}},{"type":"quote","settings":{"quote":"Arrived days before my party. The details are incredible.","name":"Illustrative review"}},{"type":"quote","settings":{"quote":"My kids' costumes were the hit of the whole street.","name":"Illustrative review"}}]}]}
{% endschema %}
