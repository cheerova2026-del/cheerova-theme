<div class="color-{{ section.settings.color_scheme }} gradient">
<div class="page-width" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px">
<p id="cheerova-wishlist-empty">Nothing here yet \u2014 tap the heart on any costume to save it for later.</p>
<div id="cheerova-wishlist-items" class="cheerova-wl-grid"></div>
</div>
</div>
<style>.cheerova-wl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:16px}.cheerova-wl-card{border-radius:12px;overflow:hidden;border:1px solid rgba(255,255,255,.08)}.cheerova-wl-card img{width:100%;aspect-ratio:3/4;object-fit:cover;display:block}.cheerova-wl-info{padding:12px;display:flex;flex-direction:column;gap:6px;font-size:1.4rem}.cheerova-wl-info a{color:currentColor;text-decoration:none}.cheerova-wl-info button{background:none;border:none;color:currentColor;opacity:.7;cursor:pointer;text-align:left;padding:0;font-size:1.2rem;text-decoration:underline}</style>
<script src="{{ 'cheerova-wishlist.js' | asset_url }}" defer></script>
{% schema %}
{"name":"Cheerova wishlist","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme","default":"scheme-1"},{"type":"range","id":"padding_top","min":0,"max":100,"step":4,"unit":"px","label":"Padding top","default":36},{"type":"range","id":"padding_bottom","min":0,"max":100,"step":4,"unit":"px","label":"Padding bottom","default":52}]}
{% endschema %}
