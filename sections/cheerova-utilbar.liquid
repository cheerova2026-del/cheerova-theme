<div class="color-{{ section.settings.color_scheme }} gradient cheerova-utilbar">
<div class="page-width cheerova-utilbar__row">
{% for block in section.blocks %}<span class="cheerova-utilbar__item" {{ block.shopify_attributes }}><span class="cheerova-utilbar__icon">{% case block.settings.icon %}{% when 'truck' %}<svg viewBox="0 0 24 24"><path d="M3 6h11v9H3zM14 9h4l3 3v3h-7z"/><circle cx="7" cy="17" r="1.6"/><circle cx="17" cy="17" r="1.6"/></svg>{% when 'shield' %}<svg viewBox="0 0 24 24"><path d="M12 2l8 3v6c0 5-3.4 9-8 11-4.6-2-8-6-8-11V5z"/><path d="M9 12l2 2 4-4" fill="none" stroke="#14101C" stroke-width="2"/></svg>{% when 'headset' %}<svg viewBox="0 0 24 24"><path d="M4 13a8 8 0 0 1 16 0" fill="none" stroke="currentColor" stroke-width="2"/><rect x="3" y="13" width="4" height="6" rx="1.4"/><rect x="17" y="13" width="4" height="6" rx="1.4"/></svg>{% when 'refresh' %}<svg viewBox="0 0 24 24"><path d="M20 12a8 8 0 1 1-2.3-5.6M20 4v4h-4" fill="none" stroke="currentColor" stroke-width="2"/></svg>{% endcase %}</span>{{ block.settings.text }}</span>{% endfor %}
</div>
</div>
<style>
.cheerova-utilbar{font-size:1.25rem}
.cheerova-utilbar__row{display:flex;align-items:center;justify-content:center;gap:34px;flex-wrap:wrap;padding:9px 0}
.cheerova-utilbar__item{display:inline-flex;align-items:center;gap:8px;font-weight:500;letter-spacing:.02em}
.cheerova-utilbar__icon svg{width:16px;height:16px;display:block;fill:currentColor}
@media(max-width:749px){.cheerova-utilbar__row{gap:18px}.cheerova-utilbar__item:nth-child(n+3){display:none}}
</style>
{% schema %}
{"name":"Cheerova utility bar","class":"cheerova-utilbar-section","settings":[{"type":"color_scheme","id":"color_scheme","label":"Color scheme","default":"scheme-2"},{"type":"range","id":"padding_top","min":0,"max":40,"step":2,"unit":"px","label":"Padding top","default":0},{"type":"range","id":"padding_bottom","min":0,"max":40,"step":2,"unit":"px","label":"Padding bottom","default":0}],"blocks":[{"type":"item","name":"Item","settings":[{"type":"select","id":"icon","label":"Icon","default":"truck","options":[{"value":"truck","label":"Truck"},{"value":"shield","label":"Shield"},{"value":"headset","label":"Headset"},{"value":"refresh","label":"Refresh"}]},{"type":"text","id":"text","label":"Text","default":"Free shipping"}]}],"max_blocks":4,"presets":[{"name":"Cheerova utility bar","blocks":[{"type":"item","settings":{"icon":"truck","text":"Free shipping over $50"}},{"type":"item","settings":{"icon":"shield","text":"30-day money-back guarantee"}},{"type":"item","settings":{"icon":"headset","text":"24/7 customer support"}}]}]}
{% endschema %}
