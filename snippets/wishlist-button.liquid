<style>.cheerova-wishlist-btn{display:flex;align-items:center;justify-content:center;gap:.8rem;width:100%;margin-top:1rem}.cheerova-wishlist-btn svg{width:1.8rem;height:1.8rem;fill:none;stroke:currentColor;stroke-width:1.6px}.cheerova-wishlist-btn[aria-pressed="true"] svg{fill:currentColor}</style>
<button type="button" class="button button--secondary cheerova-wishlist-btn" data-wishlist-toggle data-product-handle="{{ product.handle }}" data-product-title="{{ product.title | escape }}" data-product-url="{{ product.url }}" data-product-image="{{ product.featured_image | image_url: width: 400 }}" data-product-price="{{ product.price | money | escape }}" data-label-add="Add to wishlist" data-label-remove="Saved to wishlist" aria-pressed="false"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M12 21s-7.5-4.7-10-9.3C.6 8.8 2.3 5 6 5c2.2 0 3.6 1.2 4.5 2.6L12 9l1.5-1.4C14.4 6.2 15.8 5 18 5c3.7 0 5.4 3.8 4 6.7C19.5 16.3 12 21 12 21z"/></svg><span data-wishlist-label>Add to wishlist</span></button>
<script src="{{ 'cheerova-wishlist.js' | asset_url }}" defer></script>
